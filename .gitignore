dist/
build/
*.egg

# Node.js / TypeScript
node_modules/
*.log
npm-debug.log*
*.tsbuildinfo
dist/
build/

# === IDE / OS ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp

